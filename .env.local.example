# Environment
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_NODE_ENV=local

# Beta Testing (set to false to disable beta mode)
NEXT_PUBLIC_BETA_MODE=true

# OAuth Configuration
# Get Google OAuth Client ID from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here

# Get Facebook App ID from: https://developers.facebook.com/apps/
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id-here
